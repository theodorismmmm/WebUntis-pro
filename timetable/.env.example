# Kippenberg Timetable - Environment Variables
# Copy this file to .env and fill in your credentials

# WebUntis school identifier (e.g. kippenberg-gymnasium)
SCHOOL=kippenberg-gymnasium

# WebUntis server hostname (e.g. nessa.webuntis.com)
UNTIS_HOST=nessa.webuntis.com

# Your WebUntis username
UNTIS_USER=

# Your WebUntis password
UNTIS_PASSWORD=

# Port for the web server (optional, default: 3000)
PORT=3000
